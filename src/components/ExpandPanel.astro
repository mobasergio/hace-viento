---
import type { Direction } from "../lib/wind/direction";

interface Props {
  windAngle: number;
  direction: Direction;
  gust: number | null;
  temp: number | null;
  precip: number | null;
  tide: string | null;
}

const { windAngle, direction, gust, temp, precip, tide } = Astro.props;

const needleAngle = windAngle + 180;
const wobbleDur = (1.2 + ((windAngle * 7) % 100) / 125).toFixed(2);

const fmt = (v: number | null, fallback = "--") =>
  v !== null ? String(v) : fallback;

interface Stat {
  label: string;
  value: string;
  unit: string;
  text?: boolean;
}

const stats: Stat[] = [
  { label: "RÁFAGAS", value: fmt(gust), unit: gust !== null ? "km/h" : "" },
  { label: "TEMPERATURA", value: fmt(temp), unit: temp !== null ? "°C" : "" },
  {
    label: "PRECIPITACIÓN",
    value: fmt(precip),
    unit: precip !== null ? "mm/h" : "",
  },
  { label: "MAREA", value: tide ?? "--", unit: "", text: true },
];

const ticks = Array.from({ length: 72 }, (_, i) => {
  const a = (i * 5 * Math.PI) / 180;
  const isMajor = i % 9 === 0;
  const r1 = isMajor ? 74 : 80;
  const x1 = 100 + Math.sin(a) * r1;
  const y1 = 100 - Math.cos(a) * r1;
  const x2 = 100 + Math.sin(a) * 84;
  const y2 = 100 - Math.cos(a) * 84;
  return { x1, y1, x2, y2, isMajor };
});

const cardinals = [
  { l: "N", x: 100, y: 34 },
  { l: "E", x: 166, y: 104 },
  { l: "S", x: 100, y: 174 },
  { l: "O", x: 34, y: 104 },
];
---

<div class="panel">
  <div class="panel__header">
    <span>AMPLIACIÓN · DETALLE</span>
    <span>ESTACIÓN TARIFA</span>
  </div>

  <div class="panel__name">
    <div>
      <div class="panel__sublabel">NOMBRE DEL VIENTO</div>
      <div class="panel__local">{direction.local}</div>
    </div>
    <div class="panel__name-right">
      <div class="panel__sublabel">RUMBO</div>
      <div class="panel__bearing">{direction.code} · {direction.deg}°</div>
    </div>
  </div>

  <div class="panel__grid">
    <svg
      class="compass"
      viewBox="0 0 200 200"
      aria-label={`Brújula apuntando a ${direction.name}`}
    >
      <defs>
        <radialGradient id="compass-halo" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.12"
          ></stop>
          <stop offset="65%" stop-color="var(--accent)" stop-opacity="0.04"
          ></stop>
          <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"
          ></stop>
        </radialGradient>
      </defs>
      <circle cx="100" cy="100" r="92" fill="url(#compass-halo)"></circle>
      <circle
        cx="100"
        cy="100"
        r="92"
        fill="none"
        stroke="currentColor"
        stroke-width="0.7"
        opacity="0.35"></circle>
      <circle
        cx="100"
        cy="100"
        r="84"
        fill="currentColor"
        fill-opacity="0.04"
        stroke="currentColor"
        stroke-width="0.4"
        opacity="0.5"></circle>

      {
        ticks.map((t) => (
          <line
            x1={t.x1}
            y1={t.y1}
            x2={t.x2}
            y2={t.y2}
            stroke="currentColor"
            stroke-width={t.isMajor ? 1.2 : 0.5}
            opacity={t.isMajor ? 0.9 : 0.45}
          />
        ))
      }

      {
        cardinals.map((c) => (
          <text
            x={c.x}
            y={c.y}
            text-anchor="middle"
            font-size="11"
            font-weight="700"
            fill="currentColor"
            font-family="Inter Tight Variable"
            opacity="0.9"
          >
            {c.l}
          </text>
        ))
      }

      <g
        class="needle"
        style={`transform: rotate(${needleAngle}deg); animation-duration: ${wobbleDur}s;`}
      >
        <path d="M 100 40 L 107 62 L 100 57 L 93 62 Z" fill="var(--accent)"
        ></path>
        <line
          x1="100"
          y1="62"
          x2="100"
          y2="138"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"></line>
        <circle cx="100" cy="138" r="3.5" fill="currentColor" opacity="0.75"
        ></circle>
      </g>
      <circle cx="100" cy="100" r="4" fill="currentColor"></circle>
      <circle cx="100" cy="100" r="1.6" fill="var(--accent)"></circle>
    </svg>

    <div class="panel__stats">
      {
        stats.map((s) => (
          <div class="stat">
            <div class="stat__label">{s.label}</div>
            <div class={`stat__value${s.text ? " stat__value--text" : ""}`}>
              {s.value}
              <span class="stat__unit">{s.unit}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .panel {
    color: var(--card-ink);
    border-top: 1px solid color-mix(in srgb, var(--card-ink) 18%, transparent);
    padding-top: 20px;
    position: relative;
  }

  .panel::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 32px;
    height: 1px;
    background: var(--accent);
    opacity: 0.75;
  }

  .panel__header {
    display: flex;
    justify-content: space-between;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 1.2px;
    color: var(--card-ink);
    font-weight: 600;
    margin-bottom: 14px;
  }

  .panel__name {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 14px 16px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--card-ink) 9%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-ink) 14%, transparent);
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
  }

  .panel__name::before {
    content: "";
    position: absolute;
    left: 0;
    top: 12%;
    width: 3px;
    height: 76%;
    background: var(--accent);
    border-radius: 0 2px 2px 0;
    opacity: 0.85;
  }

  .panel__sublabel {
    font-size: 9px;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    color: var(--card-ink);
    letter-spacing: 1.2px;
    font-weight: 600;
    margin-bottom: 3px;
    text-transform: uppercase;
  }

  .panel__local {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: capitalize;
  }

  .panel__name-right {
    text-align: right;
  }

  .panel__bearing {
    font-size: 14px;
    font-weight: 600;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
  }

  .panel__grid {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 20px;
    align-items: center;
  }

  @media (max-width: 460px) {
    .panel__grid {
      grid-template-columns: 1fr;
      justify-items: center;
    }
  }

  .compass {
    width: 160px;
    height: 160px;
    color: var(--card-ink);
    flex-shrink: 0;
  }

  .needle {
    transform-origin: 100px 100px;
    animation: needle-wobble 1.5s ease-in-out infinite;
  }

  @keyframes needle-wobble {
    0%,
    100% {
      translate: 0 0;
    }
    50% {
      translate: 0 -0.4px;
    }
  }

  .panel__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .stat {
    padding: 12px 14px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--card-ink) 9%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-ink) 14%, transparent);
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .stat:hover {
    background: color-mix(in srgb, var(--card-ink) 13%, transparent);
    border-color: color-mix(in srgb, var(--accent) 40%, var(--card-ink) 60%);
  }

  .stat__label {
    font-size: 9px;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    color: var(--card-ink);
    letter-spacing: 1.2px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .stat__value {
    font-size: 21px;
    font-weight: 700;
    margin-top: 4px;
    letter-spacing: -0.02em;
    line-height: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stat__value--text {
    font-size: 15px;
    letter-spacing: 0.02em;
  }

  .stat__unit {
    font-size: 10px;
    color: var(--card-ink);
    margin-left: 4px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
</style>
